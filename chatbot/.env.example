# Copy this file to ".env" and paste your real key. Never commit the real .env.
# Get a key at https://console.anthropic.com/ (Settings → API Keys).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: port for the local/standalone server (defaults to 3000).
# PORT=3000

# Comma-separated list of sites allowed to call /api/chat from a browser.
# Leave unset for local dev. SET THIS before going public so the endpoint
# can't be used as a free Claude proxy from other origins.
# ALLOWED_ORIGINS=https://friscosmilesdentistry.com,https://www.friscosmilesdentistry.com

# Optional rate limit (per IP). Defaults: 15 requests per 60s.
# RATE_LIMIT=15
# RATE_WINDOW_MS=60000
